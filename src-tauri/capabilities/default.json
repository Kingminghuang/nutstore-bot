{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability with scoped sidecar spawn permissions",
  "remote": {
    "urls": [
      "http://127.0.0.1:3000/*",
      "http://localhost:3000/*"
    ]
  },
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/nsbot-sidecar",
          "sidecar": true,
          "args": false
        }
      ]
    }
  ]
}
