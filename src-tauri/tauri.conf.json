{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NutstoreBot",
  "version": "0.1.0",
  "identifier": "com.nutstore.bot",
  "build": {
    "devUrl": "http://localhost:13000",
    "beforeDevCommand": "cd ../frontend && npm run dev -- --port 13000",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "NutstoreBot",
        "width": 1320,
        "height": 880,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "../frontend/public/icon-light-32x32.png"
    ],
    "externalBin": [
      "binaries/nsbot-sidecar"
    ],
    "resources": [
      "runtime/**/*"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
